VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional live service endpoints. Fran CRM defaults to mocked responses until set.
VITE_FRAN_CRM_URL=
VITE_SKUMS_API_URL=
VITE_SKUMS_API_KEY=

# Direct Postgres connection string for migrations.
# Prefer the Supabase pooler URL when direct db.<project-ref>.supabase.co DNS is unavailable.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-1-your-region.pooler.supabase.com:6543/postgres

SUPABASE_DB_PASSWORD=your-db-password
# If SUPABASE_DB_URL is absent, the migration runner can derive a direct URL
# from VITE_SUPABASE_URL + SUPABASE_DB_PASSWORD.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
